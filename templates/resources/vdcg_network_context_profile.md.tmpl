## Advanced Usage

Reference a Network Context Profile in a VDC Group Firewall Rule for Layer 7 filtering:

```terraform
resource "cloudavenue_vdcg_network_context_profile" "ssl_strict" {
  vdc_group_name = cloudavenue_vdcg.example.name
  name           = "ssl-tls12-only"

  attribute = [
    {
      app_id = "SSL"
      sub_attribute = [
        { type = "TLS_VERSION", values = ["TLS_V12", "TLS_V13"] }
      ]
    }
  ]
}

resource "cloudavenue_vdcg_firewall" "example" {
  vdc_group_name = cloudavenue_vdcg.example.name
  rules = [
    {
      name        = "allow outbound strict SSL"
      action      = "ALLOW"
      direction   = "OUT"
      ip_protocol = "IPV4"

      network_context_profile_ids = [cloudavenue_vdcg_network_context_profile.ssl_strict.id]
    }
  ]
}
```

